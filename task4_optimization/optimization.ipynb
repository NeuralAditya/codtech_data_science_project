from pulp import *

# Create problem
prob = LpProblem("Maximize Profit", LpMaximize)

# Variables
x = LpVariable('Product_A', lowBound=0)
y = LpVariable('Product_B', lowBound=0)

# Objective
prob += 40*x + 30*y

# Constraints
prob += 2*x + y <= 100
prob += x + y <= 80

# Solve
prob.solve()

print("Product A:", x.varValue)
print("Product B:", y.varValue)
print("Total Profit:", value(prob.objective))